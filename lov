<div class="caption">يا خراشي علي الادب</div>

</div>

<div class="text" id="text"></div>

<script>
// عداد الأيام مع بعض
const startDate = new Date("2025-04-04");
function updateCounter(){
const now = new Date();
const diff = now - startDate;
const days = Math.floor(diff/(1000*60*60*24));
document.getElementById("counter").innerHTML =
"بقالنا مع بعض ❤️ " + days + " يوم";
}
setInterval(updateCounter,1000);
updateCounter();

// قلوب متحركة
function createHeart(){
const heart=document.createElement("div");
heart.classList.add("heart");
heart.style.left=Math.random()*100+"vw";
heart.style.fontSize=(Math.random()*20+10)+"px";
heart.innerHTML="❤";
document.body.appendChild(heart);
setTimeout(()=>{heart.remove()},5000);
}
setInterval(createHeart,200);

// رسالة
const message = `كل سنة وانتي أجمل وأغلى إنسانة في حياتي ❤️

النهارده مش مجرد عيد ميلاد...
ده اليوم اللي الدنيا نورت فيه ❤️

4 / 4 / 2025
أجمل يوم في حياتي...

من وقتها وأنا بقيت شخص تاني
بقيت بحب الحياة علشان فيها انتي

انتي مش بس حبيبتي...
انتي روحي وقلبي وكل دنيتي

وعد مني...
إني أفضل جنبك مهما حصل ❤️`;

let i=0;
function typeWriter(){
if(i<message.length){
document.getElementById("text").innerHTML += message.charAt(i);
i++;
setTimeout(typeWriter,40);
}
}
window.onload = () => typeWriter();

// زر تشغيل/كتم الموسيقى
const music=document.getElementById("music");
function toggleMusic(){
music.paused ? music.play() : music.pause();
}
</script>

</body>
</html>
