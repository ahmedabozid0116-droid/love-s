<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>❤️ ليكي انتي ❤️</title>
<style>
body{
margin:0;
font-family:Arial, sans-serif;
color:rgb(245, 10, 10);
text-align:center;
overflow-x:hidden;
background: linear-gradient(-45deg, #ff758c, #ff7eb3, #6a11cb, #2575fc);
background-size: 400% 400%;
animation: bg 10s infinite alternate;
}

/* تدرج متحرك */
@keyframes bg{
0%{background-position:0% 50%}
100%{background-position:100% 50%}
}

/* شاشة القفل */
#lockScreen{
position:fixed;
top:0; left:0;
width:100%; height:100%;
background: rgba(224, 54, 202, 0.5);
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
z-index:999;
padding:20px;
}

/* القفل */
.lock{
font-size:60px;
animation:pulse 2s infinite;
margin:15px 0;
}
@keyframes pulse{
0%,100%{transform:scale(1)}
50%{transform:scale(1.2)}
}

/* نص القفل */
#lockText{
font-size:20px;
margin-bottom:10px;
}

/* عداد الوقت */
#timeLeft{
font-size:16px;
margin-top:10px;
opacity:0.9;
}

/* قلوب */
.heart{
position:absolute;
top:-10px;
color:white;
animation:fall 5s linear infinite;
}
@keyframes fall{
0%{transform:translateY(-10px)}
100%{transform:translateY(110vh)}
}
</style>
</head>
<body>

<div id="lockScreen">
<div id="lockText">المفاجأة لسه مجتش ❤️</div>
<div class="lock">🔒</div>
<div id="timeLeft"></div>
</div>

<script>
// الوقت المحدد لفتح المفاجأة
const openTime = new Date("2026-03-18T00:00:00"); // عدل حسب اليوم والساعة

function updateLock(){
let now = new Date();
if(now >= openTime){
window.location.href="love.html"; // الانتقال للصفحة الثانية
return;
}
let diff = openTime - now;
let h=Math.floor(diff/(1000*60*60));
let m=Math.floor(diff/(1000*60)%60);
let s=Math.floor(diff/1000%60);
document.getElementById("timeLeft").innerHTML = `فاضل ${h} ساعة و ${m} دقيقة و ${s} ثانية ❤️`;
}
setInterval(updateLock,1000);
updateLock();

// قلوب متحركة
function createHeart(){
const heart=document.createElement("div");
heart.classList.add("heart");
heart.style.left=Math.random()*100+"vw";
heart.style.fontSize=(Math.random()*20+10)+"px";
heart.innerHTML="❤";
document.body.appendChild(heart);
setTimeout(()=>{heart.remove()},5000);
}
setInterval(createHeart,200);
</script>

</body>
</html>
